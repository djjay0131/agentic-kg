# Job Service Dockerfile
# Lean image for Cloud Run Jobs — core package only (no API/FastAPI/uvicorn)
#
# Build: docker build -f docker/Dockerfile.job -t agentic-kg-job .
# Run:   docker run --env-file .env agentic-kg-job

# Build stage
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy source code for installation
COPY pyproject.toml ./
COPY packages/core/ packages/core/

# Create and use virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install only the core package (no API dependencies)
RUN pip install --upgrade pip \
    && pip install ./packages/core

# Runtime stage
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/packages/core/src \
    PATH="/opt/venv/bin:$PATH"

# Create non-root user
RUN groupadd --gid 1000 appgroup \
    && useradd --uid 1000 --gid appgroup --shell /bin/bash --create-home appuser

WORKDIR /app

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv

# Copy application source (core only)
COPY packages/core/src/ packages/core/src/

# Change ownership
RUN chown -R appuser:appgroup /app

USER appuser

# No port — this is a job, not a service
# No health check — Cloud Run Jobs manages lifecycle

# Run the job runner
CMD ["python", "-m", "agentic_kg.job_runner"]
